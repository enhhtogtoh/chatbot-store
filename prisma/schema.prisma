generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
   
}

model Product {
    id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  discountPrice Float?
  brand       String
  category    String
  subcategory String?
  colors      String[]
  sizes       String[]
  images      String[]
  stock       Int      @default(0)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  isFeatured  Boolean  @default(false)
  isTrending  Boolean  @default(false)
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
